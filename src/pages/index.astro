---
import CategoryBento from '../components/CategoryBento.astro';
import HeroGlass from '../components/HeroGlass.astro';
import LatestPostsGrid from '../components/LatestPostsGrid.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import JsonLd from '../components/JsonLd.astro';
import { getTopLevelCategories } from '../lib/categories';
import { calculatorTools } from '../lib/calculators/metadata';
import { getOverviewContent } from '../lib/overview';
import { fetchPostsByCategory } from '../lib/wordpress';

const [topCategories, overview] = await Promise.all([getTopLevelCategories(), getOverviewContent()]);
const categoryPosts = Object.fromEntries(
	await Promise.all(
		topCategories.slice(0, 3).map(async (category) => [
			category.slug,
			category.wordpressCategoryId ? await fetchPostsByCategory(category.wordpressCategoryId, 6) : []
		])
	)
);

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": "Gini Loh",
	"alternateName": "GiniLoh",
	"url": Astro.site?.toString() || "https://giniloh.com/",
	"potentialAction": {
		"@type": "SearchAction",
		"target": `${Astro.site?.toString() || "https://giniloh.com/"}?s={search_term_string}`,
		"query-input": "required name=search_term_string"
	}
};
---

<BaseLayout
	title="Gini Loh | Salary Acceleration & Wealth Automation Systems"
	description="Practical roadmaps and calculators for professional compensation modeling, asset TCO, and friction-free financial systems."
>
	<link slot="head" rel="canonical" href={new URL('/', Astro.site).toString()} />
	<JsonLd slot="head" data={websiteSchema} />
	<HeroGlass overview={overview} topCategories={topCategories} />

	<section class="mt-20" aria-labelledby="homepage-calculators">
		<div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
			<div>
				<p class="section-eyebrow">Start here</p>
				<h2 id="homepage-calculators" class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
					Pick the calculator for your next money move
				</h2>
			</div>
			<a href="/calculators/" class="btn-inline text-sm">Browse all calculators <span aria-hidden="true">-></span></a>
		</div>

		<div class="mt-8 grid gap-5 md:grid-cols-3">
			{calculatorTools.map((tool) => (
				<a
					href={tool.href}
					class="group panel-soft flex min-h-64 flex-col rounded-2xl p-6 transition duration-300 hover:scale-105 hover:border-cyan-500/50 hover:shadow-[0_0_40px_rgba(56,189,248,0.35)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400 motion-reduce:hover:scale-100"
				>
					<div class="flex items-center justify-between">
						<div class="rounded-lg bg-cyan-500/10 p-2 text-cyan-300">
							<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 7h16M7 4v6m10-6v6M6 14h4v4H6v-4Zm8 0h4v4h-4v-4Z" />
							</svg>
						</div>
						<span class="font-mono text-xs text-slate-500 transition group-hover:text-cyan-400">PUBLIC</span>
					</div>
					<h3 class="mt-4 text-xl font-semibold text-slate-100">{tool.title}</h3>
					<p class="mt-2 font-mono text-xs uppercase tracking-[0.22em] text-emerald-300/75">{tool.utility}</p>
					<p class="mt-3 flex-1 text-sm leading-7 text-slate-400">{tool.description}</p>
					<span class="mt-5 text-sm font-semibold text-cyan-300 transition group-hover:text-cyan-100">
						Open {tool.title} <span aria-hidden="true">-></span>
					</span>
				</a>
			))}
		</div>
	</section>

	<CategoryBento categories={topCategories} postsByCategory={categoryPosts} />
	
	<LatestPostsGrid />

	<section class="mt-32 overflow-hidden rounded-[2rem] border border-slate-800 bg-slate-900 shadow-2xl">
		<div class="grid gap-px bg-slate-800 lg:grid-cols-3">
			<a href="/calculators/lease-break/" class="group bg-slate-950 p-8 transition hover:bg-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400">
				<p class="font-mono text-xs uppercase tracking-widest text-cyan-400">Renters</p>
				<h2 class="mt-4 text-2xl font-bold text-white">Leaving a lease early?</h2>
				<p class="mt-3 text-sm leading-7 text-slate-400">Estimate the penalty before you email your landlord or sign a new lease.</p>
				<span class="mt-6 inline-flex text-sm font-semibold text-cyan-300 transition group-hover:text-cyan-100">Run lease break calculator -></span>
			</a>
			<a href="/categories/" class="group bg-slate-950 p-8 transition hover:bg-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400">
				<p class="font-mono text-xs uppercase tracking-widest text-emerald-400">Research</p>
				<h2 class="mt-4 text-2xl font-bold text-white">Need more context first?</h2>
				<p class="mt-3 text-sm leading-7 text-slate-400">Browse category hubs to get the background before you act on a high-stakes decision.</p>
				<span class="mt-6 inline-flex text-sm font-semibold text-cyan-300 transition group-hover:text-cyan-100">Browse categories -></span>
			</a>
			<a href="/about/" class="group bg-slate-950 p-8 transition hover:bg-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400">
				<p class="font-mono text-xs uppercase tracking-widest text-blue-400">About</p>
				<h2 class="mt-4 text-2xl font-bold text-white">Understand the site’s angle</h2>
				<p class="mt-3 text-sm leading-7 text-slate-400">See how Gini Loh approaches expensive choices, uncertainty, and practical decision support.</p>
				<span class="mt-6 inline-flex text-sm font-semibold text-cyan-300 transition group-hover:text-cyan-100">Read about Gini Loh -></span>
			</a>
		</div>
	</section>
</BaseLayout>
