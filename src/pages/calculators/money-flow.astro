---
import CalculatorShell from '../../components/calculators/CalculatorShell.astro';
import JsonLd from '../../components/JsonLd.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCalculatorBySlug, getCalculatorSchema } from '../../lib/calculators/metadata';

import MoneyFlowSimulator from '../../components/calculators/react/MoneyFlowSimulator';

const calculator = getCalculatorBySlug('money-flow');
const schema = calculator && Astro.site ? getCalculatorSchema(calculator, Astro.site) : null;
---

<BaseLayout
	title="Frictionless Money Flow Simulator | Gini Loh"
	description="Visualize automated account routing: from checking, through retirement matches, HSAs, and index fund allocation."
>
	<link slot="head" rel="canonical" href={new URL('/calculators/money-flow/', Astro.site).toString()} />
	{schema ? <JsonLd slot="head" data={schema} /> : null}

	<CalculatorShell
		eyebrow="Automation Simulator"
		title="Frictionless Money Flow Simulator"
		description="Map and configure automated money pipelines to route savings, retirement matching, tax-sheltered accounts, and taxable indexing without manual budgeting."
	>
		<div slot="calculator">
			<MoneyFlowSimulator client:load />
		</div>

		<div slot="aside" class="grid gap-6">
			<article class="overflow-hidden rounded-[1.8rem] border border-violet-500/20 bg-[linear-gradient(135deg,rgba(46,16,101,0.92),rgba(2,6,23,0.98)_70%,rgba(139,92,246,0.12))] p-6 shadow-[0_0_40px_rgba(139,92,246,0.08)]">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-violet-200/80">Loh-Friction Philosophy</p>
				<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">Never budget manually again</h2>
				<p class="mt-4 text-sm leading-7 text-slate-300">
					Budgeting apps focus on looking backward at what you spent. Automation engines look forward by routing cash at the moment of deposit, eliminating friction and making investment compounding automatic.
				</p>
			</article>
		</div>
	</CalculatorShell>
</BaseLayout>
