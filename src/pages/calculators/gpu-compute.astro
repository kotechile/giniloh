---
import CalculatorShell from '../../components/calculators/CalculatorShell.astro';
import JsonLd from '../../components/JsonLd.astro';
import LocalVsCloudGpuCalculator from '../../components/calculators/react/LocalVsCloudGpuCalculator';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCalculatorBySlug, getCalculatorSchema } from '../../lib/calculators/metadata';
import { fetchPostBySlug } from '../../lib/wordpress';
import RelatedArticleCard from '../../components/calculators/RelatedArticleCard.astro';

const calculator = getCalculatorBySlug('gpu-compute');
const schema = calculator && Astro.site ? getCalculatorSchema(calculator, Astro.site) : null;

const title = "GPU TCO Analyzer";
const description = "Compare the TCO of building a local deep learning GPU workstation against renting cloud GPU compute instances.";
const eyebrow = "GPU TCO Analysis";

const faqItems = [
	{
		question: 'How is the local GPU TCO calculated?',
		answer: 'We sum the selected GPU cost, the customizable base system components overhead (CPU, RAM, motherboard, cooling, power supply), the active electricity cost under TDP load, and an annual 5% hardware maintenance budget.'
	},
	{
		question: 'How is cloud storage cost factored in?',
		answer: 'Unlike some simple calculators, we include persistent cloud storage costs (assumed at $0.15/GB/month) for large datasets or model checkpoints, which can add up significantly over time.'
	},
	{
		question: 'What is hardware depreciation?',
		answer: 'Deep learning workstations depreciate around 35% in residual value over a 2-3 year period as newer LLMs emerge requiring more VRAM. This makes renting highly competitive for short projects.'
	}
];

const post = await fetchPostBySlug('self-hosted-ai-when-to-buy-vs-rent-gpus');
---

<BaseLayout
	title="GPU TCO Analyzer | Gini Loh"
	description={description}
>
	<link slot="head" rel="canonical" href={new URL('/calculators/gpu-compute/', Astro.site).toString()} />
	{schema ? <JsonLd slot="head" data={schema} /> : null}

	<CalculatorShell
		eyebrow={eyebrow}
		title={title}
		description={description}
	>
		<div slot="calculator">
			<LocalVsCloudGpuCalculator client:load />
		</div>

		<article slot="aside" class="overflow-hidden rounded-[1.8rem] border border-cyan-500/20 bg-[linear-gradient(135deg,rgba(8,47,73,0.92),rgba(2,6,23,0.98)_70%,rgba(16,185,129,0.12))] p-6 shadow-[0_0_40px_rgba(34,211,238,0.08)]">
			<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-200/80">TCO analysis</p>
			<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">How to evaluate</h2>
			<ol class="mt-5 grid gap-4 text-sm leading-7 text-slate-300">
				<li>1. Configure your average active compute hours per day and days per month.</li>
				<li>2. Select your local hardware graphics card and add system component overhead.</li>
				<li>3. Compare electricity costs and cloud storage fees across major providers.</li>
			</ol>
			<div class="mt-6 rounded-[1.3rem] border border-white/10 bg-white/5 p-4">
				<p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-slate-500">TCO Logic</p>
				<p class="mt-2 text-xs leading-6 text-slate-300">
					We factor in full GPU & system power TDP, electricity rate, system component overhead, depreciation, setup fees, and cloud storage volumes for an accurate comparison.
				</p>
			</div>
		</article>

		<article slot="aside" class="panel-soft rounded-[1.8rem] border border-slate-800/90 bg-slate-900/45 p-6 shadow-2xl backdrop-blur-md">
			<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-300/70">Video Guide</p>
			<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">GPU TCO Video Guide</h2>
			<div class="mt-5 overflow-hidden rounded-[1.2rem] border border-white/10 bg-black aspect-video relative">
				<iframe
					class="absolute top-0 left-0 w-full h-full"
					src="https://www.youtube.com/embed/zFejBECgJX4"
					title="GPU TCO Analyzer Tutorial"
					frameborder="0"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
					allowfullscreen
				></iframe>
			</div>
		</article>

		<article slot="aside" class="panel-soft rounded-[1.8rem] border border-slate-800/90 bg-slate-900/45 p-6 shadow-2xl backdrop-blur-md">
			<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-300/70">FAQ</p>
			<div class="mt-5 grid gap-4">
				{faqItems.map((item) => (
					<div class="rounded-[1.2rem] border border-slate-800/80 bg-slate-950/55 p-4">
						<h2 class="text-base font-semibold text-white">{item.question}</h2>
						<p class="mt-2 text-sm leading-7 text-slate-400">{item.answer}</p>
					</div>
				))}
			</div>
		</article>

		{post && <RelatedArticleCard slot="aside" post={post} />}
	</CalculatorShell>
</BaseLayout>
