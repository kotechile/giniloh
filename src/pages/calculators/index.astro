---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { calculatorTools } from '../../lib/calculators/metadata';
import { fetchPostBySlug } from '../../lib/wordpress';

const categories = [
	{
		title: 'Career & Compensation Strategy',
		description: 'Model raises, job-hopping scenarios, total compensation offers, and relocation payback timelines to maximize your earning potential.',
		slugs: ['raise-velocity', 'total-comp', 'relocation-cost', 'career-ai-resilience']
	},
	{
		title: 'Wealth & Investment Automation',
		description: 'Simulate frictionless money routing, index fund allocations, tax shelter optimizations, and automated cash flows.',
		slugs: ['money-flow']
	},
	{
		title: 'Decision-Intelligence & TCO Analysis',
		description: 'Run objective cost-benefit analyses on SaaS workarounds, local vs. cloud GPU compute, laptop repairs, and premium consumer investments.',
		slugs: ['decision-intelligence', 'coffee-arbitrage', 'tech-debt-repair', 'no-code-terminator', 'gpu-compute']
	},
	{
		title: 'Housing & Rental Strategy',
		description: 'Quantify landlord exit costs, early lease break options, and the financial trade-offs of apartment hunting.',
		slugs: ['lease-break']
	}
] as const;

// Mapping of calculators to related WordPress post slugs
const calculatorArticlesMap: Record<string, string[]> = {
	'gpu-compute': ['self-hosted-ai-when-to-buy-vs-rent-gpus'],
	'relocation-cost': ['calculate-your-career-relocation-payback'],
	'money-flow': [
		'the-blueprint-behind-giniloh-money-flow',
		'how-to-simulate-emergency-expense-protection',
		'how-to-use-giniloh-to-simulate-automate-and-backtest-frictionless'
	],
	'raise-velocity': ['jobs-switch-calculator-step-by-step-profit-guide'],
	'total-comp': ['negotiate-job-offer-with-giniloh-visualizer'],
	'coffee-arbitrage': ['is-a-3000-espresso-maker-machine-worth-it'],
	'decision-intelligence': [
		'ebike-costs-per-use-calculator-for-commuters'
	],
	'tech-debt-repair': ['replace-laptop-screen-let-this-decision-engine-do-the-math'],
	'lease-break': ['lease-break-calculator-3-must-know-scenarios'],
	'no-code-terminator': ['zapier-notion-integration-calculate-your-tinkering-tax']
};

// Fetch all unique articles required in parallel
const allArticleSlugs = Array.from(new Set(Object.values(calculatorArticlesMap).flat()));
const fetchedPosts = await Promise.all(
	allArticleSlugs.map(async (slug) => {
		try {
			const post = await fetchPostBySlug(slug);
			return post ? [slug, post] : null;
		} catch (e) {
			console.error(`Failed to fetch article for slug: ${slug}`, e);
			return null;
		}
	})
);

const postBySlugMap = Object.fromEntries(
	fetchedPosts.filter((item): item is [string, any] => item !== null)
);
---

<BaseLayout
	title="Decision Calculators & Financial Tools | Gini Loh"
	description="Free public interactive decision-intelligence calculators. Run the numbers on career relocation, raises, job-hopping compensation, equity value, and automated investments."
>
	<link slot="head" rel="canonical" href={new URL('/calculators/', Astro.site).toString()} />

	<section class="pt-32">
		<p class="section-eyebrow">Interactive Decision Engines</p>
		<h1 class="mt-4 max-w-4xl text-5xl font-bold tracking-tight text-white sm:text-6xl">
			Run the numbers.<br />Eliminate the guesswork.
		</h1>
		<p class="mt-6 max-w-3xl text-lg leading-8 text-slate-400">
			A centralized library of practical decision-intelligence tools for ambitious professionals. Evaluate career moves, project compounding raises, audit workflow tinkering taxes, and simulate automated wealth systems with live inputs.
		</p>
	</section>

	<div class="mt-16 space-y-20" aria-label="Calculator library">
		{categories.map((category) => {
			const toolsInCategory = calculatorTools.filter((tool) =>
				(category.slugs as readonly string[]).includes(tool.slug)
			);
			if (toolsInCategory.length === 0) return null;

			return (
				<section aria-labelledby={`cat-${category.title.toLowerCase().replace(/\s+/g, '-')}`}>
					<div class="border-l-2 border-cyan-500/50 pl-4 mb-8">
						<h2
							id={`cat-${category.title.toLowerCase().replace(/\s+/g, '-')}`}
							class="text-2xl font-bold tracking-tight text-white sm:text-3xl"
						>
							{category.title}
						</h2>
						<p class="mt-2 max-w-3xl text-sm leading-6 text-slate-400">
							{category.description}
						</p>
					</div>

					<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
						{toolsInCategory.map((tool) => {
							const relatedSlugs = calculatorArticlesMap[tool.slug] || [];
							const relatedPosts = relatedSlugs.map(slug => postBySlugMap[slug]).filter(Boolean);

							return (
								<article class="panel-soft flex h-full flex-col rounded-[1.8rem] border border-slate-800/90 bg-slate-900/40 p-6 shadow-2xl backdrop-blur-md transition duration-300 hover:scale-105 hover:border-cyan-500/40 hover:shadow-[0_0_40px_rgba(56,189,248,0.22)] motion-reduce:hover:scale-100">
									<div class="flex items-center justify-between gap-4">
										<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-300/70">{tool.status}</p>
										<span class="rounded-full border border-slate-700/80 bg-slate-950/60 px-3 py-1 font-mono text-[0.68rem] uppercase tracking-[0.22em] text-slate-400">
											Calculator
										</span>
									</div>
									<h3 class="mt-6 text-2xl font-semibold tracking-tight text-white">{tool.title}</h3>
									<p class="mt-3 font-mono text-xs uppercase tracking-[0.22em] text-emerald-300/75">{tool.utility}</p>
									<p class="mt-3 flex-1 text-sm leading-7 text-slate-400">{tool.description}</p>
									<a
										href={tool.href}
										class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-cyan-300 transition hover:text-cyan-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400"
									>
										Open calculator
										<span aria-hidden="true">-></span>
									</a>

									{relatedPosts.length > 0 && (
										<div class="mt-6 border-t border-slate-800/80 pt-4 space-y-3">
											<p class="font-mono text-[0.62rem] uppercase tracking-[0.2em] text-slate-500 font-bold">Related Guides</p>
											<div class="space-y-3">
												{relatedPosts.map((post) => (
													<a 
														href={`/${post.slug}/`} 
														class="group/article flex items-center gap-3 rounded-xl bg-slate-950/40 p-2 border border-transparent hover:border-slate-850 hover:bg-slate-950/80 transition"
													>
														{post.featuredImage && (
															<img
																src={post.featuredImage}
																alt={post.featuredImageAlt || post.title}
																class="h-10 w-14 rounded-lg object-cover bg-slate-900 border border-slate-850 transition duration-300 group-hover/article:scale-105"
																loading="lazy"
															/>
														)}
														<div class="flex-1 min-w-0">
															<h4 class="text-[0.78rem] font-medium text-slate-300 group-hover/article:text-cyan-300 transition line-clamp-2 leading-tight">
																{post.title}
															</h4>
														</div>
													</a>
												))}
											</div>
										</div>
									)}
								</article>
							);
						})}
					</div>
				</section>
			);
		})}
	</div>
</BaseLayout>

