---
import CalculatorShell from '../../components/calculators/CalculatorShell.astro';
import JsonLd from '../../components/JsonLd.astro';
import DecisionIntelligenceCalculator from '../../components/calculators/react/DecisionIntelligenceCalculator';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCalculatorBySlug, getCalculatorSchema } from '../../lib/calculators/metadata';

const calculator = getCalculatorBySlug('decision-intelligence');
const schema = calculator && Astro.site ? getCalculatorSchema(calculator, Astro.site) : null;

const faqItems = [
	{
		question: 'What is the "Opportunity Cost" in this model?',
		answer:
			'Opportunity cost represents the lost revenue and business value caused by diverting senior engineers away from building core product differentiators to manage commoditized plumbing like user authentication.'
	},
	{
		question: 'How does the "Adapted 5,000 Rule" work?',
		answer:
			'Adapted from the HVAC industry, it multiplies the structural age of a custom codebase (in years) by the immediate labor cost required to remediate tech debt. If the result is $5,000 or more, rebuilding or buying a standard managed solution is mathematically superior to continuing to patch it.'
	},
	{
		question: 'What does "FTE" stand for in maintenance overhead?',
		answer:
			'FTE stands for Full-Time Equivalent. A 50% FTE upkeep burden means that ongoing package updates, API endpoints maintenance, and security patch tasks consume roughly half of a developer\'s total monthly hours (80 hours).'
	}
];
---

<BaseLayout
	title="Decision Intelligence CIAM Builder | Gini Loh"
	description="Evaluate the true total cost of ownership (TCO) comparing custom user authentication against premium SaaS providers like Clerk and Auth0."
>
	<link slot="head" rel="canonical" href={new URL('/calculators/decision-intelligence/', Astro.site).toString()} />
	{schema ? <JsonLd slot="head" data={schema} /> : null}

	<CalculatorShell
		eyebrow="Decision Intelligence Framework"
		title="CIAM Build vs. Buy Calculator"
		description="Stress-test your operational strategy. Compare upfront engineering CapEx against the multi-year hidden OpEx of security maintenance, regulatory audits, and developer opportunity cost."
	>
		<div slot="calculator">
			<DecisionIntelligenceCalculator client:load />
		</div>

		<div slot="aside" class="grid gap-6">
			<article class="overflow-hidden rounded-[1.8rem] border border-cyan-500/20 bg-[linear-gradient(135deg,rgba(8,47,73,0.92),rgba(2,6,23,0.98)_70%,rgba(16,185,129,0.12))] p-6 shadow-[0_0_40px_rgba(34,211,238,0.08)]">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-200/80">Operator notes</p>
				<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">How to use this estimate well</h2>
				<ol class="mt-5 grid gap-4 text-sm leading-7 text-slate-300">
					<li>1. Set your expected **Monthly Active Users (MAUs)** to match your current scale or target scaling horizon.</li>
					<li>2. Adjust the **Loaded Developer Rate** and **Initial Custom Build Time** based on your regional hiring cost.</li>
					<li>3. Select your target **Compliance Level Goal** (like SOC 2 Type II) to model hidden audit prep overheads.</li>
					<li>4. Toggle the **Strategic Risk Assessment** checkboxes to highlight Sunk Cost biases or Key-Person liabilities.</li>
				</ol>
				<div class="mt-6 rounded-[1.3rem] border border-white/10 bg-white/5 p-4">
					<p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-slate-500">Best use case</p>
					<p class="mt-2 text-sm leading-7 text-slate-200">
						Compare your current custom authentication maintenance velocity against a standard SaaS platform's volume pricing to justify your migration roadmap to internal stakeholders.
					</p>
				</div>
			</article>

			<article class="panel-soft rounded-[1.8rem] border border-slate-800/90 bg-slate-900/45 p-6 shadow-2xl backdrop-blur-md">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-emerald-300/80">Formulas</p>
				<div class="mt-4 rounded-[1.3rem] border border-slate-800/90 bg-slate-950/60 p-5 font-mono text-[11px] leading-6 text-slate-200 grid gap-4">
					<div>
						<p class="text-emerald-400 font-bold">Custom Build TCO Model:</p>
						<p>TCO = Build + 3×Compliance + 36×Maintenance + Opportunity Cost</p>
					</div>
					<div>
						<p class="text-cyan-400 font-bold">SaaS Managed TCO Model:</p>
						<p>TCO = Integration Labor + 36×Monthly Subscription</p>
					</div>
					<div>
						<p class="text-indigo-400 font-bold">Software Debt Index:</p>
						<p>Index = Codebase Age × Remediation Labor Cost</p>
					</div>
				</div>
				<p class="mt-4 text-xs leading-5 text-slate-400">
					The engine factors in a baseline developer opportunity cost ($150,000 over 3 years) representing the lost engineering hours that could have been spent developing core features.
				</p>
			</article>

			<article class="panel-soft rounded-[1.8rem] border border-slate-800/90 bg-slate-900/45 p-6 shadow-2xl backdrop-blur-md">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-300/70">FAQ</p>
				<div class="mt-5 grid gap-4">
					{faqItems.map((item) => (
						<div class="rounded-[1.2rem] border border-slate-800/80 bg-slate-950/55 p-4">
							<h3 class="text-sm font-semibold text-white">{item.question}</h3>
							<p class="mt-2 text-xs leading-5 text-slate-400">{item.answer}</p>
						</div>
					))}
				</div>
			</article>
		</div>
	</CalculatorShell>
</BaseLayout>
