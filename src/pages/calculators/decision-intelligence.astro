---
import CalculatorShell from '../../components/calculators/CalculatorShell.astro';
import JsonLd from '../../components/JsonLd.astro';
import DecisionIntelligenceCalculator from '../../components/calculators/react/DecisionIntelligenceCalculator';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCalculatorBySlug, getCalculatorSchema } from '../../lib/calculators/metadata';

const calculator = getCalculatorBySlug('decision-intelligence');
const schema = calculator && Astro.site ? getCalculatorSchema(calculator, Astro.site) : null;

const faqItems = [
	{
		question: 'What is the difference between Enterprise and Personal TCO?',
		answer:
			'Enterprise TCO evaluates loaded developer salaries, compliance certification audits, and roadmap opportunity costs. Personal TCO translates these same concepts into personal financial and lifestyle metrics, such as billable/leisure time value, home utility expenses, physical maintenance upkeep, and asset depreciation.'
	},
	{
		question: 'How do the different Repair-vs-Replace thresholds work?',
		answer:
			'The Adapted Consumer "5,000 Rule" uses an asset debt index (structural age multiplied by immediate repair cost). For major home infrastructure (HVAC systems, roofs, cars), a score of 5,000 or higher triggers a replace verdict. For personal electronics (laptops, phones), the threshold is scaled down to 1,500.'
	},
	{
		question: 'How is "Tinkering Tax" calculated?',
		answer:
			'It multiplies the hours you spend troubleshooting, manual copy-pasting, or fixing fragile workarounds per month by your personal opportunity value of time. If this monthly labor value exceeds a paid integrated app subscription fee, you are paying a hidden "tinkering tax" by using a "free" stack.'
	}
];
---

<BaseLayout
	title="Decision Intelligence Calculator | Gini Loh"
	description="Stress-test high-value decisions. Compare upfront CapEx against multi-year hidden OpEx for user authentication pipelines, personal espresso machines, asset repairs, and tinkering taxes."
>
	<link slot="head" rel="canonical" href={new URL('/calculators/decision-intelligence/', Astro.site).toString()} />
	{schema ? <JsonLd slot="head" data={schema} /> : null}

	<CalculatorShell
		eyebrow="Decision Intelligence Framework"
		title="Build vs. Buy & Life Decision Engine"
		description="Stop guessing. Transition from subjective, unstructured assessments to mathematically sound, objective decisions for both your software platform and your lifestyle assets."
	>
		<div slot="calculator">
			<DecisionIntelligenceCalculator client:load />
		</div>

		<div slot="aside" class="grid gap-6">
			<article class="overflow-hidden rounded-[1.8rem] border border-cyan-500/20 bg-[linear-gradient(135deg,rgba(8,47,73,0.92),rgba(2,6,23,0.98)_70%,rgba(16,185,129,0.12))] p-6 shadow-[0_0_40px_rgba(34,211,238,0.08)]">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-200/80">Operator notes</p>
				<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">How to use this engine</h2>
				<ol class="mt-5 grid gap-4 text-sm leading-7 text-slate-300">
					<li>1. **Select your Mode:** Choose between **Enterprise CIAM**, **Cost-Per-Use**, **Repair vs Replace**, or **Tinkering Tax** tabs at the top.</li>
					<li>2. **Input your Specifics:** Adjust the sliders to match your operational scales, loaded developer rates, personal time value, or repair quotes.</li>
					<li>3. **Observe the Matrix:** Review the **Visible vs. Invisible Cost Matrix** to analyze the "iceberg" costs of the decision.</li>
					<li>4. **Stress-Test Risk Biases:** Complete the step-4 checklists to flag Sunk Cost Fallacies or Key-Person Turnover risks.</li>
				</ol>
				<div class="mt-6 rounded-[1.3rem] border border-white/10 bg-white/5 p-4">
					<p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-slate-500">Decision Rationale</p>
					<p class="mt-2 text-sm leading-7 text-slate-200">
						Whether building custom authentication middleware or buying a premium home espresso maker, the engine normalizes capital allocation into utilization metrics to highlight the financial break-even point.
					</p>
				</div>
			</article>

			<article class="panel-soft rounded-[1.8rem] border border-slate-800/90 bg-slate-900/45 p-6 shadow-2xl backdrop-blur-md">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-emerald-300/80">Mathematical Formulas</p>
				<div class="mt-4 rounded-[1.3rem] border border-slate-800/90 bg-slate-950/60 p-5 font-mono text-[11px] leading-6 text-slate-200 grid gap-4">
					<div>
						<p class="text-emerald-400 font-bold">Custom Build TCO Model:</p>
						<p>TCO = Build + 3×Compliance + 36×Maintenance + Opportunity Cost</p>
					</div>
					<div>
						<p class="text-cyan-400 font-bold">Personal CPU TCO Model:</p>
						<p>TCO = Sticker Price + Operating Cost + Upkeep Cost</p>
					</div>
					<div>
						<p class="text-indigo-400 font-bold">Asset Tech Debt Index:</p>
						<p>Index = Age × Immediate Repair Cost</p>
					</div>
					<div>
						<p class="text-rose-400 font-bold">Monthly Tinkering Time Tax:</p>
						<p>Tinkering Cost = Troubleshoot Hours × Value of Time</p>
					</div>
				</div>
				<p class="mt-4 text-xs leading-5 text-slate-400">
					All calculations run client-side instantly via React hooks and can be bookmarked or saved locally on your device automatically.
				</p>
			</article>

			<article class="panel-soft rounded-[1.8rem] border border-slate-800/90 bg-slate-900/45 p-6 shadow-2xl backdrop-blur-md">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-cyan-300/70">FAQ</p>
				<div class="mt-5 grid gap-4">
					{faqItems.map((item) => (
						<div class="rounded-[1.2rem] border border-slate-800/80 bg-slate-950/55 p-4">
							<h3 class="text-sm font-semibold text-white">{item.question}</h3>
							<p class="mt-2 text-xs leading-5 text-slate-400">{item.answer}</p>
						</div>
					))}
				</div>
			</article>
		</div>
	</CalculatorShell>
</BaseLayout>
