---
import CalculatorShell from '../../components/calculators/CalculatorShell.astro';
import JsonLd from '../../components/JsonLd.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCalculatorBySlug, getCalculatorSchema } from '../../lib/calculators/metadata';

const calculator = getCalculatorBySlug('total-comp');
const schema = calculator && Astro.site ? getCalculatorSchema(calculator, Astro.site) : null;
---

<BaseLayout
	title="Total Compensation & Equity Visualizer | Gini Loh"
	description="Model base salary, cash bonuses, and vesting RSUs or options with stock growth assumptions to evaluate tech offers."
>
	<link slot="head" rel="canonical" href={new URL('/calculators/total-comp/', Astro.site).toString()} />
	{schema ? <JsonLd slot="head" data={schema} /> : null}

	<CalculatorShell
		eyebrow="Compensation Calculator"
		title="Total Compensation Visualizer"
		description="Break down base salary, target bonuses, and vesting schedules (RSUs/Options) to model the true cash flow value of an offer."
	>
		<div slot="calculator" class="rounded-[2rem] border border-indigo-500/20 bg-slate-900/60 p-8 shadow-2xl backdrop-blur-md">
			<div class="flex flex-col items-center justify-center py-12 text-center">
				<div class="h-16 w-16 rounded-full bg-indigo-500/10 border border-indigo-500/30 flex items-center justify-center mb-6">
					<svg class="w-8 h-8 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2h2a2 2 0 002-2zm12 0v-30" />
					</svg>
				</div>
				<h2 class="text-2xl font-bold text-white tracking-tight">Interactive Module Under Development</h2>
				<p class="mt-3 text-slate-400 max-w-md text-sm leading-6">
					The equity trajectory model and multi-offer comparison screen is currently scheduled for deployment in Phase 2.
				</p>
				
				<div class="mt-8 p-6 rounded-xl border border-slate-800 bg-slate-950/50 w-full max-w-sm text-left">
					<p class="font-mono text-xs uppercase tracking-widest text-slate-500">Upcoming Features</p>
					<ul class="mt-3 space-y-2 text-xs font-mono text-slate-400">
						<li>• 4-year vesting schedule projection with 1-year cliff</li>
						<li>• Equity growth assumption adjustments (flat, 10%, 20% annual)</li>
						<li>• Cash flow comparison: Offer A vs Offer B side-by-side</li>
					</ul>
				</div>
				
				<a href="/calculators/" class="mt-8 btn-primary">Back to Calculator Hub</a>
			</div>
		</div>

		<div slot="aside" class="grid gap-6">
			<article class="overflow-hidden rounded-[1.8rem] border border-indigo-500/20 bg-[linear-gradient(135deg,rgba(30,27,75,0.92),rgba(2,6,23,0.98)_70%,rgba(99,102,241,0.12))] p-6 shadow-[0_0_40px_rgba(99,102,241,0.08)]">
				<p class="font-mono text-xs uppercase tracking-[0.28em] text-indigo-200/80">Evaluation note</p>
				<h2 class="mt-3 text-2xl font-semibold tracking-tight text-white">Comparing Apples to RSUs</h2>
				<p class="mt-4 text-sm leading-7 text-slate-300">
					Tech offers often inflate their metrics by showing a total RSU grant over 4 years alongside base salary. Visualizing the actual year-by-year cash distribution is critical to avoiding poor career moves.
				</p>
			</article>
		</div>
	</CalculatorShell>
</BaseLayout>
