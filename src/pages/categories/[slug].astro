---
import { getAllCategories } from '../../lib/categories';

export async function getStaticPaths() {
	const categories = await getAllCategories();
	return categories.map((category) => ({
		params: { slug: category.slug }
	}));
}

const destination = '/#pillars';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta http-equiv="refresh" content={`0;url=${destination}`} />
		<link rel="canonical" href={new URL(destination, Astro.site).toString()} />
		<title>Redirecting to Gini Loh Pillars</title>
		<script is:inline>
			window.location.replace('/#pillars');
		</script>
	</head>
	<body>
		<a href="/#pillars">Continue to the Gini Loh pillars.</a>
	</body>
</html>
