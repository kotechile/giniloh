---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { getAllCategories, getCategoryBySlug } from '../../lib/categories';
import { fetchPostsByCategory } from '../../lib/wordpress';

export async function getStaticPaths() {
	const categories = await getAllCategories();
	return categories.map((category) => ({
		params: { slug: category.slug }
	}));
}

const { slug } = Astro.params;
const category = slug ? await getCategoryBySlug(slug) : null;

if (!category) {
	return Astro.redirect('/404');
}

const posts = category.wordpressCategoryId
	? await fetchPostsByCategory(category.wordpressCategoryId, 20)
	: [];

const siteUrl = Astro.site?.toString() || 'https://giniloh.com/';
const categoriesUrl = new URL('/categories/', siteUrl).toString();
const categoryUrl = new URL(`/categories/${category.slug}/`, siteUrl).toString();

const categorySchema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": `${category.name} | Gini Loh`,
	"description": category.description || `Browse articles, guides, and tools related to ${category.name}.`,
	"url": categoryUrl,
	"numberOfItems": posts.length,
	"itemListElement": posts.map((post, idx) => ({
		"@type": "ListItem",
		"position": idx + 1,
		"name": post.title,
		"url": new URL(`/${post.slug}/`, siteUrl).toString()
	}))
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": siteUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Categories",
			"item": categoriesUrl
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": category.name,
			"item": categoryUrl
		}
	]
};
---

<BaseLayout
	title={`${category.name} | Gini Loh`}
	description={category.description || `Browse articles, guides, and tools related to ${category.name}.`}
>
	<link slot="head" rel="canonical" href={new URL(`/categories/${category.slug}/`, Astro.site).toString()} />
	<JsonLd slot="head" data={categorySchema} />
	<JsonLd slot="head" data={breadcrumbSchema} />

	<div class="relative py-12">
		<div class="absolute inset-x-0 top-0 -z-10 h-96 bg-[radial-gradient(circle_at_top,rgba(0,112,243,0.1),transparent_60%)]"></div>
		
		<div class="mx-auto max-w-3xl">
			<a href="/categories/" class="btn-inline text-sm mb-6">
				<span aria-hidden="true">&lt;-</span> Back to categories
			</a>
			
			<p class="section-eyebrow mt-4">Decision Pillar</p>
			<h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-5xl">
				{category.name}
			</h1>
			<p class="mt-4 text-lg text-slate-400">
				{category.description || 'Guides, templates, and analytics to support decision-making in this area.'}
			</p>
		</div>

		<div class="mx-auto mt-16 max-w-5xl">
			{posts.length ? (
				<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
					{posts.map((post) => (
						<a
							href={`/${post.slug}/`}
							class="group relative flex flex-col justify-between overflow-hidden rounded-[1.8rem] border border-slate-800 bg-slate-900/40 shadow-2xl backdrop-blur-md transition duration-300 hover:scale-102 hover:border-cyan-500/50 hover:shadow-[0_0_40px_rgba(56,189,248,0.2)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400"
						>
							<div>
								{post.featuredImage ? (
									<div class="aspect-video w-full overflow-hidden border-b border-slate-800 bg-slate-950">
										<img
											src={post.featuredImage}
											alt={post.featuredImageAlt || ''}
											loading="lazy"
											class="h-full w-full object-cover opacity-75 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
										/>
									</div>
								) : (
									<div class="aspect-video w-full bg-slate-950/80 border-b border-slate-800 flex items-center justify-center text-slate-700">
										<svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2-2m-2-3V3m8 8h-6M21 12H9m0 0v-4" />
										</svg>
									</div>
								)}
								<div class="p-6">
									<div class="flex items-center gap-3 font-mono text-[0.65rem] uppercase tracking-widest text-slate-500">
										<span>{post.date ? new Date(post.date).toLocaleDateString() : 'Live'}</span>
									</div>
									<h2 class="mt-4 text-xl font-bold leading-tight text-white transition group-hover:text-cyan-400">
										{post.title}
									</h2>
									<p class="mt-3 text-sm leading-6 text-slate-400 line-clamp-3">
										{post.excerpt}
									</p>
								</div>
							</div>
							<div class="p-6 pt-0 mt-4">
								<span class="text-sm font-semibold text-cyan-400 group-hover:text-cyan-300 flex items-center gap-1">
									Read Article <span aria-hidden="true" class="transition group-hover:translate-x-1 inline-block">-></span>
								</span>
							</div>
						</a>
					))}
				</div>
			) : (
				<div class="rounded-[1.8rem] border border-slate-800 bg-slate-900/40 p-12 text-center backdrop-blur-md">
					<p class="font-mono text-sm text-slate-400">
						&gt; No articles are currently published in this pillar. Check back soon.
					</p>
				</div>
			)}
		</div>
	</div>
</BaseLayout>
