---
import BaseLayout from '../../layouts/BaseLayout.astro';
import JsonLd from '../../components/JsonLd.astro';
import { fetchAllPosts } from '../../lib/wordpress';

const posts = await fetchAllPosts(6);

const siteUrl = Astro.site?.toString() || 'https://giniloh.com/';
const pageUrl = new URL('/author/gini-loh/', siteUrl).toString();

const personSchema = {
	"@context": "https://schema.org",
	"@type": "Person",
	"name": "Gini Loh",
	"jobTitle": "Financial Systems Engineer",
	"url": pageUrl,
	"sameAs": [
		"https://www.linkedin.com/in/gini-loh-placeholder",
		"https://twitter.com/giniloh",
		"https://github.com/giniloh"
	],
	"description": "Gini Loh builds interactive decision engines and analytical frameworks to help professionals optimize compensation, evaluate assets, and automate investments.",
	"worksFor": {
		"@type": "Organization",
		"name": "Gini Loh",
		"url": siteUrl
	}
};

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": siteUrl
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Gini Loh",
			"item": pageUrl
		}
	]
};
---

<BaseLayout
	title="Gini Loh | Financial Systems Engineer & Author"
	description="Author profile and professional credentials of Gini Loh, developer of the Gini Loh decision-intelligence calculators."
>
	<link slot="head" rel="canonical" href={pageUrl} />
	<JsonLd slot="head" data={personSchema} />
	<JsonLd slot="head" data={breadcrumbSchema} />

	<div class="relative py-12 md:py-20">
		<div class="absolute inset-x-0 top-0 -z-10 h-96 bg-[radial-gradient(circle_at_top,rgba(0,112,243,0.1),transparent_60%)]"></div>
		
		<div class="mx-auto max-w-4xl">
			<!-- Author Card -->
			<div class="panel-soft rounded-[2.2rem] border border-slate-800 bg-slate-900/40 p-8 md:p-12 shadow-2xl backdrop-blur-md flex flex-col md:flex-row gap-8 items-center md:items-start">
				<div class="w-32 h-32 md:w-40 md:h-40 rounded-full bg-gradient-to-tr from-cyan-500 via-blue-500 to-emerald-400 flex items-center justify-center text-slate-950 font-bold text-4xl md:text-5xl shrink-0 shadow-lg shadow-cyan-500/10">
					GL
				</div>
				<div class="flex-1 text-center md:text-left space-y-4">
					<p class="font-mono text-xs uppercase tracking-[0.3em] text-cyan-400 font-bold">Author Profile // E-E-A-T Verified</p>
					<h1 class="text-4xl md:text-5xl font-bold tracking-tight text-white leading-tight">
						Gini Loh
					</h1>
					<p class="text-lg font-mono text-emerald-400">
						Financial Systems Engineer & Career Analyst
					</p>
					<p class="text-slate-300 leading-relaxed max-w-2xl text-base md:text-lg">
						Gini Loh spent years tearing apart compensation rubrics, testing productivity frameworks, and constructing automated portfolio spreadsheets. Today, she builds interactive tools to bring high-agency decisions and low friction strategy to ambitious professionals.
					</p>
					
					<!-- Social Verification Badges -->
					<div class="flex flex-wrap justify-center md:justify-start gap-3 pt-2">
						<a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-950/60 border border-slate-800 hover:border-cyan-500/30 text-xs font-mono text-slate-300 transition">
							<svg class="w-4 h-4 text-cyan-400" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
							LinkedIn Credibility
						</a>
						<a href="https://twitter.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-950/60 border border-slate-800 hover:border-cyan-500/30 text-xs font-mono text-slate-300 transition">
							<svg class="w-4 h-4 text-cyan-400" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-1.015-2.174-1.649-3.594-1.649-2.719 0-4.923 2.204-4.923 4.923 0 .385.043.76.127 1.119-4.091-.205-7.719-2.165-10.148-5.144-.424.656-.667 1.432-.667 2.268 0 1.708 1.1 3.214 2.772 3.86-.717-.023-1.391-.219-1.981-.547v.062c0 2.385 1.697 4.374 3.946 4.828-.413.111-.849.171-1.296.171-.317 0-.626-.03-.927-.086.626 1.956 2.444 3.379 4.6 3.419-1.685 1.321-3.808 2.108-6.115 2.108-.397 0-.79-.023-1.175-.068 2.179 1.396 4.768 2.212 7.548 2.212 9.057 0 14.01-7.507 14.01-14.01 0-.213-.005-.426-.014-.637.962-.695 1.797-1.562 2.457-2.549z"/></svg>
							Twitter / X Updates
						</a>
						<a href="https://github.com" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-slate-950/60 border border-slate-800 hover:border-cyan-500/30 text-xs font-mono text-slate-300 transition">
							<svg class="w-4 h-4 text-cyan-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
							Open Source Calculators
						</a>
					</div>
				</div>
			</div>

			<!-- Core Competency & Credentials -->
			<div class="mt-16 grid gap-6 md:grid-cols-3">
				<div class="rounded-2xl border border-slate-800 bg-slate-950 p-6 space-y-3">
					<div class="w-10 h-10 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400">
						<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
					</div>
					<h3 class="text-lg font-bold text-white">Compensation Auditing</h3>
					<p class="text-sm text-slate-400 leading-relaxed font-mono text-[0.8rem]">
						Ex-recruiter experience modeling base salary bands, cash bonuses, and vesting RSUs/options to optimize salary negotiations.
					</p>
				</div>
				<div class="rounded-2xl border border-slate-800 bg-slate-950 p-6 space-y-3">
					<div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-400">
						<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
					</div>
					<h3 class="text-lg font-bold text-white">Asset TCO & Repairs</h3>
					<p class="text-sm text-slate-400 leading-relaxed font-mono text-[0.8rem]">
						Formulating clear math parameters around complex buy-vs-lease choices, repair indexes, and tinkering taxes.
					</p>
				</div>
				<div class="rounded-2xl border border-slate-800 bg-slate-950 p-6 space-y-3">
					<div class="w-10 h-10 rounded-xl bg-violet-500/10 border border-cyan-500/20 flex items-center justify-center text-violet-400">
						<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2" /></svg>
					</div>
					<h3 class="text-lg font-bold text-white">Waterfall Automation</h3>
					<p class="text-sm text-slate-400 leading-relaxed font-mono text-[0.8rem]">
						Designing frictionless routing schemas for multi-account money waterfalls and retirement optimization strategies.
					</p>
				</div>
			</div>

			<!-- Authored Content Grid -->
			<div class="mt-20">
				<h2 class="text-2xl font-bold tracking-tight text-white mb-8">
					Guides Authored by Gini Loh
				</h2>
				
				<div class="grid gap-8 sm:grid-cols-2">
					{posts.map((post) => (
						<a
							href={`/${post.slug}/`}
							class="group relative flex flex-col justify-between overflow-hidden rounded-[1.8rem] border border-slate-800 bg-slate-900/40 shadow-2xl backdrop-blur-md transition duration-300 hover:scale-102 hover:border-cyan-500/50 hover:shadow-[0_0_40px_rgba(56,189,248,0.2)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-cyan-400"
						>
							<div>
								{post.featuredImage ? (
									<div class="aspect-video w-full overflow-hidden border-b border-slate-800 bg-slate-950">
										<img
											src={post.featuredImage}
											alt={post.featuredImageAlt || ''}
											loading="lazy"
											class="h-full w-full object-cover opacity-75 transition duration-500 group-hover:scale-105 group-hover:opacity-100"
										/>
									</div>
								) : (
									<div class="aspect-video w-full bg-slate-950/80 border-b border-slate-800 flex items-center justify-center text-slate-700">
										<svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 4a2 2 0 00-2-2m-2-3V3m8 8h-6M21 12H9m0 0v-4" />
										</svg>
									</div>
								)}
								<div class="p-6">
									<div class="flex items-center gap-3 font-mono text-[0.65rem] uppercase tracking-widest text-slate-500">
										<span>{post.date ? new Date(post.date).toLocaleDateString() : 'Live'}</span>
										{post.categoryLabel && (
											<>
												<span>•</span>
												<span class="text-cyan-400">{post.categoryLabel}</span>
											</>
										)}
									</div>
									<h3 class="mt-4 text-xl font-bold leading-tight text-white transition group-hover:text-cyan-400">
										{post.title}
									</h3>
									<p class="mt-3 text-sm leading-6 text-slate-400 line-clamp-3">
										{post.excerpt}
									</p>
								</div>
							</div>
							<div class="p-6 pt-0 mt-4">
								<span class="text-sm font-semibold text-cyan-400 group-hover:text-cyan-300 flex items-center gap-1">
									Read Article <span aria-hidden="true" class="transition group-hover:translate-x-1 inline-block">&rarr;</span>
								</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</div>
	</div>
</BaseLayout>
