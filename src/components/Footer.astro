---
import { getTopLevelCategories } from '../lib/categories';

const topCategories = await getTopLevelCategories();
---

<footer class="mt-24 border-t border-slate-800 bg-slate-950 py-16">
	<div class="mx-auto grid max-w-6xl gap-12 px-4 lg:grid-cols-[1fr_auto] lg:px-8">
		<div class="grid gap-12 md:grid-cols-2">
			<div>
				<p class="font-mono text-xs uppercase tracking-widest text-cyan-400">Gini Loh // System</p>
				<h2 class="mt-4 text-2xl font-bold tracking-tight text-slate-100">
					Technology with a purpose: smarter portfolios, fuller lives.
				</h2>
				<p class="mt-4 text-sm leading-7 text-slate-400">
					Free calculators and plain-English guides for lease breaks, career moves, portfolio automation, and money decisions.
				</p>
				
				<!-- Social Profiles -->
				<div class="mt-6 flex gap-4">
					<a href="https://twitter.com/giniloh" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-cyan-400 transition" aria-label="Twitter / X">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-1.015-2.174-1.649-3.594-1.649-2.719 0-4.923 2.204-4.923 4.923 0 .385.043.76.127 1.119-4.091-.205-7.719-2.165-10.148-5.144-.424.656-.667 1.432-.667 2.268 0 1.708 1.1 3.214 2.772 3.86-.717-.023-1.391-.219-1.981-.547v.062c0 2.385 1.697 4.374 3.946 4.828-.413.111-.849.171-1.296.171-.317 0-.626-.03-.927-.086.626 1.956 2.444 3.379 4.6 3.419-1.685 1.321-3.808 2.108-6.115 2.108-.397 0-.79-.023-1.175-.068 2.179 1.396 4.768 2.212 7.548 2.212 9.057 0 14.01-7.507 14.01-14.01 0-.213-.005-.426-.014-.637.962-.695 1.797-1.562 2.457-2.549z"/></svg>
					</a>
					<a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-cyan-400 transition" aria-label="LinkedIn">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
					</a>
					<a href="https://github.com/giniloh" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-cyan-400 transition" aria-label="GitHub">
						<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
					</a>
				</div>

				<!-- Newsletter Lead Capture -->
				<div class="mt-8 max-w-sm">
					<p class="font-mono text-[10px] uppercase tracking-[0.2em] text-slate-500 mb-3">Newsletter // Join the system builder community</p>
					<form class="flex gap-2" onsubmit="event.preventDefault(); alert('Transmission logged. Welcome to the System.'); this.reset();">
						<input 
							type="email" 
							placeholder="Enter your email" 
							required 
							aria-label="Email address for newsletter"
							class="min-w-0 flex-1 rounded-xl border border-slate-800 bg-slate-900/50 px-4 py-2 text-sm text-slate-200 placeholder-slate-500 focus:border-cyan-500/80 focus:outline-none focus:ring-1 focus:ring-cyan-500"
						/>
						<button 
							type="submit" 
							class="rounded-xl bg-cyan-500 hover:bg-cyan-400 px-4 py-2 text-xs font-bold font-mono uppercase tracking-wider text-slate-950 transition active:scale-95 shadow-md shadow-cyan-500/10"
						>
							Sync
						</button>
					</form>
				</div>
			</div>
			
			<!-- Proof of Logic Section -->
			<div class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
				<div class="flex items-center gap-2 mb-4">
					<svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
					<p class="font-mono text-xs uppercase tracking-widest text-emerald-400">Mental Model of the Week</p>
				</div>
				<h3 id="mental-model-title" class="font-bold text-slate-200">Inversion</h3>
				<p class="mt-2 text-sm text-slate-400 font-mono">
					<span id="mental-model-quote">"Instead of asking how to achieve a goal, ask how you could guarantee failure. Then avoid those actions."</span> <br/>— <span id="mental-model-author" class="text-slate-500">Carl Jacobi</span>
				</p>
			</div>

			<script>
				const mentalModels = [
					{
						title: "Inversion",
						quote: '"Instead of asking how to achieve a goal, ask how you could guarantee failure. Then avoid those actions."',
						author: "Carl Jacobi"
					},
					{
						title: "First-Principles Thinking",
						quote: '"Boil a problem down to its most fundamental truths, then reason up from there instead of reasoning by analogy."',
						author: "Aristotle"
					},
					{
						title: "Second-Order Thinking",
						quote: '"Every action has a consequence, and each consequence has a subsequent consequence. Always ask yourself: \'And then what?\'"',
						author: "Howard Marks"
					},
					{
						title: "Hanlon’s Razor",
						quote: '"Never attribute to malice that which is adequately explained by carelessness or stupidity."',
						author: "Robert J. Hanlon"
					},
					{
						title: "Map vs. Territory",
						quote: '"The description of reality is not reality itself. The abstraction is always simpler than the messy truth it represents."',
						author: "Alfred Korzybski"
					},
					{
						title: "Occam’s Razor",
						quote: '"When presented with competing hypotheses that make identical predictions, the simplest explanation is usually the correct one."',
						author: "William of Ockham"
					},
					{
						title: "Regulatory Capture",
						quote: '"A form of corruption where a regulatory agency, created to act in the public interest, instead advances the commercial or political concerns of the industry it is charged with regulating."',
						author: "George Stigler"
					},
					{
						title: "Circle of Competence",
						quote: '"Know the limits of your valuable knowledge. Operating inside your circle minimizes risk; operating outside of it guarantees failure."',
						author: "Warren Buffett"
					},
					{
						title: "Survivorship Bias",
						quote: '"The logical error of focusing on the people or things that \'survived\' a process while inadvertently overlooking those that did not, leading to false conclusions."',
						author: "Abraham Wald"
					},
					{
						title: "Regret Minimization Framework",
						quote: '"Project yourself forward to age 80 and look back on your life. Make the decision that minimizes the number of regrets you will have."',
						author: "Jeff Bezos"
					},
					{
						title: "The Lindy Effect",
						quote: '"The future life expectancy of a non-perishable technology or idea is proportional to its current age. If it has survived for 100 years, it will likely survive another 100."',
						author: "Albert Allen"
					},
					{
						title: "Pareto Principle",
						quote: '"In many systems, roughly 80% of the consequences come from 20% of the causes. Focus on the vital few, ignore the trivial many."',
						author: "Joseph M. Juran"
					},
					{
						title: "Parkinson’s Law",
						quote: '"Work expands so as to fill the time available for its completion. To get things done efficiently, set aggressive, artificial constraints."',
						author: "C. Northcote Parkinson"
					},
					{
						title: "High-Agency",
						quote: '"A refusal to accept a bad situation as unchangeable. High-agency individuals look at a wall and bend reality until a door appears."',
						author: "Nivi"
					},
					{
						title: "Chesterton’s Fence",
						quote: '"Do not remove a fence or reform a rule until you fully understand the original reason why it was put there in the first place."',
						author: "G.K. Chesterton"
					},
					{
						title: "Normal Accident Theory",
						quote: '"In highly complex, tightly coupled systems, unexpected failures are completely inevitable. The system itself makes a catastrophe \'normal\'."',
						author: "Charles Perrow"
					}
				];

				function getWeekIndex() {
					const now = new Date();
					// Use January 1, 2026 as reference base
					const baseDate = new Date(2026, 0, 1);
					const millisecondsPerWeek = 7 * 24 * 60 * 60 * 1000;
					return Math.floor((now.getTime() - baseDate.getTime()) / millisecondsPerWeek);
				}

				const weekIndex = Math.abs(getWeekIndex());
				const model = mentalModels[weekIndex % mentalModels.length];

				const titleEl = document.getElementById("mental-model-title");
				const quoteEl = document.getElementById("mental-model-quote");
				const authorEl = document.getElementById("mental-model-author");

				if (titleEl && quoteEl && authorEl) {
					titleEl.textContent = model.title;
					quoteEl.textContent = model.quote;
					authorEl.textContent = model.author;
				}
			</script>
		</div>

		<div class="grid gap-8 sm:grid-cols-2 lg:ml-12">
			<div>
				<p class="font-mono text-xs uppercase tracking-widest text-slate-500">System Map</p>
				<div class="mt-4 grid gap-3 text-sm font-mono text-slate-400">
					<a href="/" class="transition hover:text-cyan-400">Home / Dashboard</a>
					<a href="/#guides" class="transition hover:text-cyan-400">Guides</a>
					<a href="/calculators/" class="transition hover:text-cyan-400">Calculators</a>
					<a href="/about/" class="transition hover:text-cyan-400">About</a>
				</div>
			</div>
			<div>
				<p class="font-mono text-xs uppercase tracking-widest text-slate-500">Active Modules</p>
				<div class="mt-4 grid gap-3 text-sm font-mono text-slate-400">
					{topCategories.slice(0, 3).map((category) => <span>{category.name}</span>)}
					<a href="/calculators/" class="transition hover:text-cyan-400">Calculator Hub</a>
				</div>
			</div>
		</div>
	</div>
</footer>
