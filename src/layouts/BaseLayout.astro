---
import Footer from '../components/Footer.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import SiteNav from '../components/SiteNav.astro';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Headless editorial front end for Gini Loh powered by Astro and WordPress.' } = Astro.props;

const analyticsSrc = import.meta.env.PUBLIC_ANALYTICS_SRC;
const analyticsWebsiteId = import.meta.env.PUBLIC_ANALYTICS_WEBSITE_ID;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<script is:inline>
			// Prevent flash of wrong theme by setting class before paint
			(function() {
				var stored = localStorage.getItem('theme');
				if (stored === 'light' || (!stored && window.matchMedia('(prefers-color-scheme: light)').matches)) {
					document.documentElement.classList.add('light');
				}
			})();
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		{import.meta.env.DEV && (
			<>
				<meta http-equiv="Cache-Control" content="no-cache, no-store, must-revalidate" />
				<meta http-equiv="Pragma" content="no-cache" />
				<meta http-equiv="Expires" content="0" />
			</>
		)}
		{analyticsSrc && analyticsWebsiteId && (
			<>
				<script 
					async 
					defer 
					data-website-id={analyticsWebsiteId} 
					src={analyticsSrc}
					data-auto-track="false"
				></script>
				<script is:inline>
					(function() {
						window.__lastTrackedUrl = null;
						function trackUmami() {
							const currentUrl = window.location.pathname;
							if (window.umami && window.__lastTrackedUrl !== currentUrl) {
								window.__lastTrackedUrl = currentUrl;
								window.umami.track(function(props) {
									return Object.assign({}, props, { url: currentUrl });
								});
							}
						}
						if (document.readyState === 'complete') {
							trackUmami();
						} else {
							window.addEventListener('load', trackUmami, { once: true });
						}
						document.addEventListener('astro:page-load', trackUmami);
					})();
				</script>
			</>
		)}
		<title>{title}</title>
		<slot name="head" />
	</head>
	<body class="min-h-screen bg-site text-slate-200 antialiased">
		<div class="site-background">
			<div class="orb orb-one"></div>
			<div class="orb orb-two"></div>
			<div class="orb orb-three"></div>
		</div>
		<SiteNav />
		<SearchOverlay />
		<main class="relative z-10">
			<div class="mx-auto max-w-7xl xl:max-w-[1440px] 2xl:max-w-[1600px] px-4 pb-10 pt-6 sm:px-6 lg:px-8">
				<slot />
			</div>
		</main>
		<div class="relative z-10 mx-auto max-w-7xl xl:max-w-[1440px] 2xl:max-w-[1600px] px-4 sm:px-6 lg:px-8">
			<Footer />
		</div>
	</body>
</html>
